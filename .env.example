# 智谱 AI 开放平台密钥 (必填)
ZHIPUAI_API_KEY="your_api_key_here"

# 后端服务运行端口 (选填，默认为 8451)
# 如果启动时遇到“address already in use”的端口冲突报错，请取消下方注释并更换为一个空闲的四位数端口。
# API_PORT=8451

# 本地离线模型路径配置 (选填)
# 如果你有独立的显卡和提前下载好的本地模型，请取消下方注释并填入绝对路径。
# 如果不填，系统首次运行时将自动联网下载模型。
# EMBEDDING_MODEL_PATH="/path/to/your/local/bge-large-zh-v1.5"
# RERANKER_MODEL_PATH="/path/to/your/local/bge-reranker-v2-m3"

# 向量数据库持久化目录 (选填，默认为项目根目录下的 vector_dbs)
# VECTOR_DB_DIR="./vector_dbs"